# ComicCraft-Engine V2.0 - API Key 配置
# 将以下占位符替换为你的真实 API Key

# ─── LLM Provider Keys (用于剧本生成) ───
# DeepSeek: https://platform.deepseek.com 注册获取
DEEPSEEK_API_KEY=

# OpenAI: https://platform.openai.com 注册获取
OPENAI_API_KEY=

# ─── Video Provider Keys (用于视频生成 - 自定义适配器) ───
# 可灵 Kling: Access Key 和 Secret Key（用于 JWT 签名）
KLING_ACCESS_KEY=
KLING_SECRET_KEY=

# ─── 数据库与缓存 ───
DATABASE_URL=
REDIS_URL=

# 智谱AI CogVideoX-3: https://bigmodel.cn/usercenter/proj-mgmt/apikeys 获取
ZHIPU_API_KEY=

# xAI Grok Imagine (图像 + 视频): https://console.x.ai 获取
XAI_API_KEY=

# 硅基流动 FLUX Schnell: https://cloud.siliconflow.cn 获取
SILICON_API_KEY=

# Google AI (Nano Banana): https://aistudio.google.com/apikey 获取
GOOGLE_API_KEY=

# 字节极梦 Seedance 2.0
SEEDANCE_API_KEY=
